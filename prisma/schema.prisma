generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  MEDIATOR
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String?
  googleId      String?        @unique
  name          String?
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  wallet        Wallet?
  buyerIntents  EscrowIntent[] @relation("BuyerIntents")
  sellerIntents EscrowIntent[] @relation("SellerIntents")

  @@map("users")
}

model Wallet {
  id             String   @id @default(uuid())
  userId         String   @unique
  stellarAddress String
  providerId     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model EscrowIntent {
  id              String  @id @default(uuid())
  buyerId         String
  sellerId        String
  amount          Float
  status          String  @default("PENDING")
  sorobanEscrowId String?

  buyer  User @relation("BuyerIntents", fields: [buyerId], references: [id])
  seller User @relation("SellerIntents", fields: [sellerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([sellerId])
  @@map("escrow_intents")
}
